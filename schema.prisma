'use client';

import { useState } from 'react';

type Props = {
  payload: unknown;
};

export function AnalyzePanel({ payload }: Props) {
  const [text, setText] = useState('');
  const [loading, setLoading] = useState(false);

  async function handleAnalyze() {
    setLoading(true);
    setText('');
    try {
      const res = await fetch('/api/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ data: payload }),
      });
      const json = await res.json();
      setText(json.result || json.error || 'No hubo respuesta.');
    } finally {
      setLoading(false);
    }
  }

  return (
    <div className="card p-5">
      <div className="label">Asistente</div>
      <h2 className="mt-1 text-xl font-semibold text-white">Análisis de tus métricas</h2>
      <p className="mt-2 text-sm text-slate-400">
        Resume tendencias, detecta fatiga y te propone qué hacer mañana.
      </p>
      <button className="button-primary mt-4" onClick={handleAnalyze} disabled={loading}>
        {loading ? 'Analizando…' : 'Analizar ahora'}
      </button>
      <div className="mt-4 min-h-40 whitespace-pre-wrap rounded-xl bg-slate-950 p-4 text-sm leading-6 text-slate-200">
        {text || 'Todavía no has lanzado el análisis.'}
      </div>
    </div>
  );
}
